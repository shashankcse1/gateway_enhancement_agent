        {"id": "prompt_library", "label": "Prompt library governance", "priority": 2, "keywords": ["prompt library", "prompt template", "governance"]},
        {"id": "gateway_guardrails", "label": "Gateway guardrails", "priority": 2, "keywords": ["guardrail", "ai gateway", "observability"]}
      ]
    },
    {
      "id": "kong_ai",
      "name": "Kong AI Gateway",
      "urls": [
