{
  "version": 2,
  "enabled": true,
  "extraction_mode": "local",
  "description": "Free public documentation only. Local rule-based extraction — no Ollama, no paid APIs.",
  "cache_ttl_hours": 168,
  "max_pages_per_competitor": 3,
  "max_chars_per_page": 12000,
