{
  "version": 1,
  "scope": "agents_only",
  "description": "Ollama for implement/review/synthesizer subagents. Web research uses local free-source extraction (see competitor_research.json).",
  "provider": "ollama",
  "base_url": "http://127.0.0.1:11434",
  "model": "qwen2.5-coder:7b",
  "fallback_models": ["deepseek-coder:6.7b", "codellama:7b"],
  "timeout_seconds": 600,
  "temperature": 0.2,
  "num_ctx": 12288,
  "num_predict": 3072,
  "reserve_output_tokens": 3072,
  "max_prompt_tokens": 0,
  "num_gpu": -1,
  "num_thread": 0,
  "auto_implement": true,
  "max_context_files": 5,
  "max_file_chars": 8000,
  "tests_first_max_context_files": 2,
  "tests_first_max_file_chars": 3500,
  "max_design_brief_chars": 800,
  "allowed_path_prefixes": ["backend/", "frontend/"]
}
