{
  "version": 4,
  "enabled": true,
  "recipient": "shashankcse@gmail.com",
  "from_address": "gateway-agent@localhost",
  "subject_prefix": "[Gateway Agent]",
  "interval_hours": 2,
  "gap_matrix_limit": 25,
