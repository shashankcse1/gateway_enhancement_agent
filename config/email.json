    "enabled": true,
    "check_interval_minutes": 30,
    "max_stale_hours": 3,
    "stuck_running_hours": 2,
    "consecutive_failure_threshold": 3,
    "alert_cooldown_hours": 2,
    "launch_agent_label": "com.gateway.enhancement-agent",
    "check_ollama": true
  }
}
