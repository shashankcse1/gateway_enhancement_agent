# Absolute path to the gateway platform repo (quote if path contains spaces).
TARGET_REPO="/Users/you/path/to/gateway-platform"

# Loop interval when using `gateway-agent loop` (seconds). Default: 3600 (1 hour).
LOOP_INTERVAL_SECONDS=3600

# Max SDLC cycles per loop session (0 = unlimited).
MAX_CYCLES=0

# --- Local LLM (Ollama — uses Mac CPU/GPU via Metal, no cloud, no Cursor) ---
# Install: https://ollama.com then `ollama pull qwen2.5-coder:7b`
LOCAL_LLM_ENABLED=1
LOCAL_LLM_AUTO_IMPLEMENT=1
LOCAL_LLM_BASE_URL=http://127.0.0.1:11434
LOCAL_LLM_MODEL=qwen2.5-coder:7b
# LOCAL_LLM_NUM_GPU=-1   # -1 = use all GPU layers (Metal on Apple Silicon)
# LOCAL_LLM_NUM_THREAD=0 # 0 = Ollama default CPU threads
