# Absolute path to the gateway platform repo (quote if path contains spaces).
TARGET_REPO="/Users/you/path/to/gateway-platform"

# Loop interval when using `gateway-agent loop` (seconds). Default: 3600 (1 hour).
LOOP_INTERVAL_SECONDS=3600

# Max SDLC cycles per loop session (0 = unlimited).
MAX_CYCLES=0

# --- Ollama for SDLC agents only (implement / review / synthesizer) ---
# Install: https://ollama.com then `ollama pull qwen2.5-coder:7b`
LOCAL_LLM_ENABLED=1
LOCAL_LLM_AUTO_IMPLEMENT=1
LOCAL_LLM_BASE_URL=http://127.0.0.1:11434
LOCAL_LLM_MODEL=qwen2.5-coder:7b
# LOCAL_LLM_NUM_GPU=-1   # -1 = use all GPU layers (Metal on Apple Silicon)
# LOCAL_LLM_NUM_THREAD=0 # 0 = Ollama default CPU threads

# --- Parallel subagents (independent workers + synthesizer merge; uses Ollama) ---
PARALLEL_IMPLEMENT=1
PARALLEL_MAX_WORKERS=4

# --- Competitor web research (free public docs → local rule-based extraction; no Ollama) ---
COMPETITOR_WEB_RESEARCH=1
COMPETITOR_RESEARCH_CACHE_HOURS=168
COMPETITOR_RESEARCH_MODE=local

# --- Summary email (every 2 hours by default) ---
WEEKLY_EMAIL_ENABLED=1
WEEKLY_EMAIL_TO=shashankcse@gmail.com
EMAIL_INTERVAL_HOURS=2
EMAIL_GAP_MATRIX_LIMIT=25
EMAIL_CAPABILITY_MATRIX_LIMIT=40

# macOS local Postfix (no Gmail credentials required)
SMTP_MODE=local
SMTP_HOST=127.0.0.1
SMTP_PORT=25
SMTP_USE_TLS=0
SMTP_AUTH=0
SMTP_FROM=gateway-agent@localhost

# Remote relay (set SMTP_MODE=relay and uncomment below instead)
# SMTP_MODE=relay
# SMTP_USER=shashankcse@gmail.com
# SMTP_PASSWORD=your-gmail-app-password
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USE_TLS=1
# SMTP_AUTH=1

# --- Bitbucket push (autonomous agent) ---
BITBUCKET_WORKSPACE=shashankcse1
BITBUCKET_GATEWAY_REPO=gateway
BITBUCKET_AGENT_REPO=gateway_enhancement_agent
GIT_PUSH_REMOTES=bitbucket,origin
AGENT_USE_APP_SUPPORT_CLONE=1
